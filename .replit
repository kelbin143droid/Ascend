modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["zip"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[[ports]]
localPort = 23637
externalPort = 3002

[[ports]]
localPort = 23638
externalPort = 3003

[[ports]]
localPort = 23639
externalPort = 4200

[[ports]]
localPort = 23640
externalPort = 3001

[[ports]]
localPort = 23641
externalPort = 5000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install --production=false && npm run build && rm -rf node_modules"]
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "[ -d node_modules ] || npm install; npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
mockupState = "FULLSTACK"
integrations = ["javascript_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

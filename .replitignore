# Large dev-only archives at project root
*.zip
*.tar.gz
*.tar

# Export archives generated during development
exports/

# Reference images/videos uploaded during development (not served by the app)
attached_assets/

# Mockup sandbox — dev-only design tool
artifacts/

# Replit agent skills and local dev tooling
.local/

# Git history — not needed at runtime
.git/

# npm packages — installed fresh by the build command during deployment
node_modules/

# Vite/build tool cache — regenerated automatically
.cache/

# OS / editor noise
.DS_Store
*.swp
